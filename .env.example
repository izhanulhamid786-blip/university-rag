GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

GENERATOR_PROVIDER=groq
GENERATOR_MODEL=llama-3.1-8b-instant
FALLBACK_GENERATOR_MODEL=llama3-8b-8192
RAG_COLLECTION=university_kb
RAG_EMBED_MODEL=BAAI/bge-base-en-v1.5
RAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

RAG_RETRIEVAL_K=20
RAG_RERANK_TOP_K=5
RAG_RERANK_CANDIDATES=12
RAG_MAX_CONTEXT_CHARS=12000
RAG_LOCAL_FILES_ONLY=false

RAG_INCLUDE_MANUAL_RAW=true
RAG_INCLUDE_LEGACY_ROOT_RAW=false
